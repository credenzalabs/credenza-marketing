# Google Analytics measurement ID (public — replaces the hardcoded value in index.html)
VITE_GA_ID=G-XXXXXXXXXX

# Supabase edge function endpoint that receives "request access" form submissions
# (the ComingSoon + ForDesigners waitlist forms POST to this URL)
VITE_ACCESS_REQUEST_URL=https://<your-supabase-project>.supabase.co/functions/v1/vendor-request-access

# Supabase project URL + anon key — used by inline waitlist forms that POST
# directly to the designer_requests table via the PostgREST anon endpoint.
# The anon key is safe to expose; RLS policies on designer_requests allow
# anon INSERT only (no SELECT, UPDATE, DELETE from the client).
VITE_SUPABASE_URL=https://<your-supabase-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>
